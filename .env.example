# CRM (HubSpot-style private app token by default)
CRM_API_URL=https://api.hubapi.com/crm/v3/objects/contacts
CRM_API_TOKEN=your-crm-token-here

# Public: admin WhatsApp number the waitlist message is sent to.
# Digits only, with country code, no + sign. e.g. 14155551234
NEXT_PUBLIC_ADMIN_WHATSAPP=
