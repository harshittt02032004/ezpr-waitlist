# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/ezpr?retryWrites=true&w=majority

# SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sender@example.com
SMTP_PASS=app-password-here
