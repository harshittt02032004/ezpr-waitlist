@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&family=Inter:wght@300;400;500;600&display=swap');

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --primary-red: #D52B1E;
}

html.lenis, html.lenis body { height: auto; }
.lenis.lenis-smooth { scroll-behavior: auto !important; }
.lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }
.lenis.lenis-stopped { overflow: hidden; }

body {
  font-family: 'Poppins', sans-serif;
  background: linear-gradient(160deg, #0d0d0d 0%, #111010 55%, #0f0d0d 100%);
  color: rgba(255,255,255,0.92);
  min-height: 100vh;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
}

h1, h2, h3, h4, h5, h6, p { margin: 0; }

/* ── Animations ── */
@keyframes particleDrift {
  0%   { transform: translateY(-30px) translateX(0) rotate(var(--rot)); opacity: 0; }
  6%   { opacity: 1; }
  90%  { opacity: 0.4; }
  100% { transform: translateY(110vh) translateX(var(--sway)) rotate(calc(var(--rot) + 180deg)); opacity: 0; }
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(28px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes antigravityFloat {
  0%   { transform: translateY(0px); }
  50%  { transform: translateY(-18px); }
  100% { transform: translateY(0px); }
}

/* ── Stellar Galaxy Background ── */
#stellar-bg {
  position: fixed;
  inset: 0;
  width: 100vw;
  height: 100vh;
  z-index: -1;
  pointer-events: auto;
  background-color: #000;
  overflow: hidden;
}
#stellar-canvas {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  outline: none;
  will-change: transform;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
}
#stellar-cards {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  pointer-events: none;
}
.stellar-card {
  width: 85px;
  height: 115px;
  border-radius: 8px;
  box-shadow: 0 15px 30px rgba(0, 0, 0, 0.6);
  background-color: #1F2121;
  padding: 8px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  position: absolute;
  top: 0; left: 0;
  pointer-events: auto;
  cursor: pointer;
  transform-origin: center center;
  transition: box-shadow 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94), border-color 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.4s ease;
  will-change: transform, opacity;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
}
.stellar-card.hovered {
  box-shadow: 0 25px 50px rgba(49, 184, 198, 0.5), 0 0 30px rgba(49, 184, 198, 0.3);
  border-color: rgba(49, 184, 198, 0.5);
  z-index: 1000 !important;
}
.stellar-card-logo {
  width: 100%;
  height: 75px;
  border-radius: 6px;
  pointer-events: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: rgba(0, 0, 0, 0.05) 0px 5px 6px 0px;
}
.stellar-card-logo svg {
  opacity: 0.9;
}
.stellar-card-title {
  margin-top: 8px;
  text-align: center;
  color: white;
  font-size: 10px;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-family: 'Poppins', sans-serif;
  pointer-events: none;
}

#app { 
  position: relative;
  z-index: 10;
  pointer-events: none; 
}
.ez-hero, .ez-value, .ez-cta, .ez-footer { pointer-events: none; }
.ez-header { pointer-events: auto; }
.ez-logo, .ez-coming-soon, .ez-eyebrow, .ez-h1, .ez-sub, .ez-microcopy, .ez-form, .ez-btn, .ez-value-intro, .ez-h2, .ez-pain-card, .ez-value-body, .ez-cta-icon, .ez-cta-h2, .ez-cta-sub, .ez-cta-fine, .ez-footer span {
  pointer-events: auto;
}

/* ── Particles ── */
#particles {
  position: fixed;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
  z-index: 0;
}

.particle {
  position: absolute;
  top: -30px;
}

/* ── Noise overlay ── */
#noise {
  position: fixed;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
  background-repeat: repeat;
  background-size: 128px 128px;
  opacity: 0.5;
}

/* ── Ambient glow ── */
#glow {
  position: fixed;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 1000px;
  height: 600px;
  background: radial-gradient(ellipse, rgba(213,43,30,0.06) 0%, transparent 65%);
  pointer-events: none;
  z-index: 0;
}

/* ── Main wrapper ── */
#app {
  position: relative;
  z-index: 2;
}

/* ── Header ── */
.ez-header {
  padding: 32px 52px 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 100;
  transition: background 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94), backdrop-filter 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94), padding 0.4s ease;
}

.ez-header.scrolled {
  background: transparent;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
  padding-top: 18px;
  padding-bottom: 18px;
  border-bottom: none;
}

.ez-logo-link {
  display: inline-block;
  line-height: 0;
  text-decoration: none;
  transition: opacity 0.3s ease, transform 0.3s ease;
}
.ez-logo-link:hover {
  opacity: 0.9;
  transform: translateY(-1px);
}
.ez-logo-img {
  display: block;
  width: clamp(240px, 22vw, 320px);
  height: auto;
  aspect-ratio: 1 / 1;
  clip-path: inset(38% 13% 40% 14%);
  margin-top: clamp(-122px, -8.4vw, -91px);
  margin-bottom: clamp(-128px, -8.8vw, -96px);
  margin-left: clamp(-45px, -3.1vw, -34px);
  margin-right: clamp(-42px, -2.9vw, -31px);
  -webkit-user-drag: none;
  user-select: none;
}

.ez-coming-soon {
  font-family: 'Poppins', sans-serif;
  font-size: clamp(10px, 1.2vw, 12px);
  font-weight: 500;
  letter-spacing: 0.08em;
  color: #D52B1E;
  line-height: 1;
  white-space: nowrap;
  flex-shrink: 0;
  border: 1px solid rgba(213,43,30,0.5);
  padding: 4px 10px;
  border-radius: 16px;
  position: relative;
  overflow: hidden;
  background: rgba(213,43,30,0.05);
  box-shadow: 0 0 15px rgba(213,43,30,0.1);
  animation: badgePulse 3s ease-in-out infinite;
}

.ez-coming-soon::after {
  content: "";
  position: absolute;
  top: -50%;
  left: -60%;
  width: 40px;
  height: 200%;
  background: rgba(255, 255, 255, 0.2);
  transform: rotate(30deg);
  animation: badgeShine 4s infinite linear;
  filter: blur(5px);
}

@keyframes badgeShine {
  0% { left: -60%; }
  20% { left: 140%; }
  100% { left: 140%; }
}

@keyframes badgePulse {
  0%, 100% { box-shadow: 0 0 15px rgba(213,43,30,0.1); border-color: rgba(213,43,30,0.5); }
  50% { box-shadow: 0 0 25px rgba(213,43,30,0.25); border-color: rgba(213,43,30,0.8); }
}

/* ── Hero ── */
.ez-hero {
  min-height: 86vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 60px 52px 100px;
  max-width: 940px;
  margin: 0 auto;
  width: 100%;
}

.ez-eyebrow {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin-bottom: 40px;
}

.ez-eyebrow-line {
  width: 28px;
  height: 1px;
  background: #D52B1E;
  display: inline-block;
  flex-shrink: 0;
}

.ez-eyebrow-text {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.14em;
  color: #D52B1E;
}

.ez-h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(32px, 5vw, 56px);
  font-weight: 600;
  line-height: 1.05;
  text-transform: none;
  color: rgba(255,255,255,0.95);
  margin-bottom: 32px;
  max-width: 820px;
}

.ez-h1 .red { color: #D52B1E; }

.ez-hero-secondary {
  font-family: 'Inter', sans-serif;
  font-size: clamp(15px, 1.6vw, 17px);
  font-weight: 400;
  color: rgba(255,255,255,0.36);
  letter-spacing: 0.02em;
  line-height: 1.7;
  margin-top: 12px;
  margin-bottom: 52px;
}

.ez-sub {
  font-family: 'Inter', sans-serif;
  font-size: clamp(15px, 2vw, 18px);
  font-weight: 400;
  line-height: 1.7;
  color: rgba(255,255,255,0.45);
  max-width: 500px;
  margin-bottom: 52px;
}

.ez-microcopy {
  font-family: 'Poppins', sans-serif;
  font-size: 12px;
  color: rgba(255,255,255,0.45);
  margin-top: 16px;
  letter-spacing: 0.04em;
}

/* ── Form ── */
.ez-form {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12px;
  width: 100%;
  max-width: 520px;
  margin: 0 auto;
}
.ez-form.cta { max-width: 460px; }
.ez-form .magnetic-wrap {
  display: inline-block;
}
.ez-form .ez-btn {
  min-width: 220px;
}

.ez-input {
  flex: 1;
  padding: 14px 18px;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 2px;
  color: rgba(255,255,255,0.9);
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  outline: none;
  transition: border-color 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), background 0.4s ease, box-shadow 0.4s ease;
  min-width: 0;
}

.ez-input::placeholder { color: rgba(255,255,255,0.25); transition: color 0.3s ease; }
.ez-input:focus { border-color: rgba(213,43,30,0.5); background: rgba(255,255,255,0.06); box-shadow: 0 0 20px rgba(213,43,30,0.06); }
.ez-input:focus::placeholder { color: rgba(255,255,255,0.15); }

.ez-btn {
  padding: 14px 28px;
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.1em;
  border: none;
  border-radius: 30px;
  white-space: nowrap;
  flex-shrink: 0;
  transition: background 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  min-height: 48px;
  background: #D52B1E;
  color: #ffffff;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 15px rgba(213, 43, 30, 0.2);
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
}

.ez-btn:hover { background: #e63125; box-shadow: 0 8px 30px rgba(213, 43, 30, 0.35); }
.ez-btn:active { transform: scale(0.96); transition-duration: 0.1s; }

.ez-btn::before {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    120deg,
    transparent,
    rgba(255, 255, 255, 0.3),
    transparent
  );
  transition: all 0.6s;
}

.ez-btn:hover::before {
  left: 100%;
}

.magnetic-wrap {
  display: inline-block;
  padding: 20px;
  margin: -20px;
  position: relative;
  z-index: 1;
}
.ez-btn:disabled { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.3); cursor: not-allowed; opacity: 1; }

.ez-success {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  color: #D52B1E;
}

.ez-success-title {
  font-family: 'Poppins', sans-serif;
  font-size: 15px;
  font-weight: 600;
  letter-spacing: 0.08em;
}

.ez-success-sub {
  font-family: 'Poppins', sans-serif;
  font-size: 13px;
  color: rgba(255,255,255,0.4);
}

/* ── Value Section ── */
.ez-value {
  padding: 100px 52px;
  border-top: 1px solid rgba(255,255,255,0.06);
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.ez-value::before {
  content: '';
  position: absolute;
  top: -1px;
  left: 50%;
  transform: translateX(-50%);
  width: 300px;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(213,43,30,0.3), transparent);
  opacity: 0;
  transition: opacity 1s ease;
}
.ez-value.visible::before { opacity: 1; }

.ez-value-intro {
  font-family: 'Inter', sans-serif;
  font-size: clamp(15px, 1.6vw, 17px);
  font-weight: 400;
  color: rgba(255,255,255,0.36);
  letter-spacing: 0.02em;
  margin-bottom: 48px;
  max-width: 640px;
  line-height: 1.7;
}

.ez-h2 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(30px, 5vw, 56px);
  font-weight: 600;
  line-height: 1.05;
  text-transform: none;
  color: rgba(255,255,255,0.92);
  margin-bottom: 64px;
  max-width: 680px;
}

.ez-h2 .red { color: #D52B1E; }

.ez-pain-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.06);
  max-width: 900px;
  width: 100%;
  margin-bottom: 80px;
}

.ez-pain-card {
  padding: 13px;
  background: rgba(13,13,13,0.9);
  display: flex;
  flex-direction: column;
  gap: 12px;
  transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94), border-color 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94), background 0.6s ease;
  border: 1px solid rgba(255, 255, 255, 0.04);
  cursor: default;
  position: relative;
  will-change: transform;
  backface-visibility: hidden;
}

.ez-pain-card:hover {
  transform: translateY(-6px) scale(1.015);
  border-color: rgba(213, 43, 30, 0.35);
  box-shadow: 0 16px 40px rgba(0, 0, 0, 0.5), 0 0 30px rgba(213, 43, 30, 0.08);
  background: rgba(18,18,18,0.95);
  z-index: 2;
}

.ez-pain-card:hover .ez-pain-icon {
  transform: scale(1.1) rotate(-5deg);
}

.ez-pain-card .ez-pain-icon {
  transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.ez-pain-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 4px;
}

.ez-pain-icon {
  color: #D52B1E;
  opacity: 0.95;
  flex-shrink: 0;
}

.ez-pain-label {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.08em;
  color: #D52B1E;
  line-height: 1.1;
}

.ez-pain-label .white {
  color: rgba(255,255,255,0.95);
}

.ez-pain-text {
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 400;
  color: rgba(255,255,255,0.48);
  line-height: 1.7;
}

.ez-value-body {
  max-width: 600px;
}

.ez-value-body p:first-child {
  font-family: 'Inter', sans-serif;
  font-size: clamp(15px, 1.8vw, 18px);
  font-weight: 400;
  color: rgba(255,255,255,0.58);
  line-height: 1.7;
  margin-bottom: 20px;
}

.ez-value-body p:last-child {
  font-family: 'Poppins', sans-serif;
  font-size: 13px;
  color: rgba(255,255,255,0.45);
  letter-spacing: 0.06em;
}

/* ── CTA Section ── */
.ez-cta {
  padding: 48px 52px 120px;
  border-top: 1px solid rgba(255,255,255,0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  position: relative;
}

.ez-cta::before {
  content: '';
  position: absolute;
  top: -1px;
  left: 50%;
  transform: translateX(-50%);
  width: 300px;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(213,43,30,0.3), transparent);
  opacity: 0;
  transition: opacity 1s ease;
}
.ez-cta.visible::before { opacity: 1; }

.ez-cta-icon {
  margin-bottom: 32px;
  opacity: 0.65;
  line-height: 1;
}

.ez-cta-h2 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(28px, 4.5vw, 52px);
  font-weight: 600;
  text-transform: none;
  color: rgba(255,255,255,0.92);
  line-height: 1.1;
  margin-bottom: 20px;
  max-width: 560px;
}

.ez-cta-h2 em {
  font-style: italic;
  font-weight: 500;
}

.ez-cta-sub {
  font-family: 'Inter', sans-serif;
  font-size: 16px;
  font-weight: 400;
  color: rgba(255,255,255,0.36);
  margin-bottom: 44px;
  line-height: 1.7;
  max-width: 380px;
}

.ez-cta-fine {
  font-family: 'Poppins', sans-serif;
  font-size: 12px;
  color: rgba(255,255,255,0.45);
  margin-top: 16px;
  letter-spacing: 0.04em;
}

/* ── Footer ── */
.ez-footer {
  padding: 28px 52px;
  border-top: 1px solid rgba(255,255,255,0.06);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.ez-footer span {
  font-family: 'Poppins', sans-serif;
  font-size: 12px;
  color: rgba(255,255,255,0.45);
}

/* ── Fade-in ── */
.fade-in {
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  will-change: opacity, transform;
}

.fade-in.visible {
  opacity: 1;
  transform: translateY(0);
}

/* ── Staggered child reveals ── */
.fade-in.visible .ez-eyebrow,
.fade-in.visible .ez-h1,
.fade-in.visible .ez-hero-secondary,
.fade-in.visible .ez-form,
.fade-in.visible .ez-microcopy,
.fade-in.visible .ez-value-intro,
.fade-in.visible .ez-h2,
.fade-in.visible .ez-value-body,
.fade-in.visible .ez-cta-h2,
.fade-in.visible .ez-cta-sub {
  animation: smoothReveal 1s cubic-bezier(0.25, 0.46, 0.45, 0.94) both;
}

.fade-in.visible .ez-eyebrow { animation-delay: 0s; }
.fade-in.visible .ez-h1 { animation-delay: 0.12s; }
.fade-in.visible .ez-hero-secondary { animation-delay: 0.22s; }
.fade-in.visible .ez-form { animation-delay: 0.32s; }
.fade-in.visible .ez-microcopy { animation-delay: 0.4s; }
.fade-in.visible .ez-value-intro { animation-delay: 0.08s; }
.fade-in.visible .ez-h2 { animation-delay: 0.16s; }
.fade-in.visible .ez-value-body { animation-delay: 0.24s; }
.fade-in.visible .ez-cta-h2 { animation-delay: 0.1s; }
.fade-in.visible .ez-cta-sub { animation-delay: 0.2s; }

@keyframes smoothReveal {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── Eyebrow line grow animation ── */
.fade-in .ez-eyebrow-line {
  transform: scaleX(0);
  transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.fade-in.visible .ez-eyebrow-line {
  transform: scaleX(1);
  transition-delay: 0.3s;
}

/* ── Tablet ── */
@media (max-width: 900px) {
  .ez-header  { padding: 28px 32px 20px; }
  .ez-hero    { padding: 52px 32px 80px; }
  .ez-value   { padding: 72px 32px; }
  .ez-cta     { padding: 48px 32px 88px; }
  .ez-footer  { padding: 24px 32px; }
}

/* ── Mobile ── */
@media (max-width: 640px) {
  .ez-header  { padding: 20px 20px 16px; align-items: center; }
  .ez-logo-img { width: clamp(200px, 55vw, 260px); }
  .ez-coming-soon { font-size: 10px; padding: 3px 8px; margin-right: 0; }
  .ez-hero    { padding: 40px 20px 72px; min-height: 78vh; }
  .ez-value   { padding: 56px 20px; }
  .ez-pain-grid { grid-template-columns: 1fr; margin-bottom: 52px; }
  .ez-cta     { padding: 60px 20px 72px; }
  .ez-footer  { padding: 20px; flex-direction: column; gap: 8px; text-align: center; }
  .ez-form    { flex-direction: column; max-width: 100% !important; }
  .ez-btn     { width: 100%; padding: 16px 28px; min-height: 52px; }
}
